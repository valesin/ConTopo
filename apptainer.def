Bootstrap: docker
From: ubuntu:22.04

%post
    # Prevent interactive prompts during apt installation
    export DEBIAN_FRONTEND=noninteractive
    
    # Install system dependencies
    apt-get update && apt-get install -y \
        python3.11 \
        python3.11-venv \
        python3-pip \
        git \
        build-essential \
        curl
    
    # Install uv globally in the container using the official installer
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/usr/local/bin" sh
    
    # Create the mount point for the persistent directory
    mkdir -p /persistent_repo

%environment
    export REPO_DIR=/persistent_repo/ConTopo
    export VENV_DIR=$REPO_DIR/.venv
    export PYTHONPATH=$REPO_DIR
    
    # Make sure we use the venv automatically if opening a shell
    export PATH="$VENV_DIR/bin:$PATH"
    
    # CRITICAL for Apptainer bind mounts: Forces uv to copy files instead of 
    # using hardlinks, which often fail across different file systems/bind mounts.
    export UV_LINK_MODE=copy

%runscript
    # 1. Enforce persistence: ensure /persistent_repo is bind-mounted and writable
    if [ ! -w "/persistent_repo" ]; then
        echo "===================================================================="
        echo "ERROR: /persistent_repo is not writable."
        echo "You MUST bind a directory on the host server to /persistent_repo."
        echo "Example: apptainer run --bind /home/user/my_data:/persistent_repo container.sif"
        echo "===================================================================="
        exit 1
    fi

    # 2. Clone the repo if it's the first time running on this server/folder
    if [ ! -d "$REPO_DIR" ]; then
        echo "First run in this directory! Cloning repository..."
        git clone https://github.com/valesin/ConTopo.git "$REPO_DIR"
    fi
    
    # Move into the codebase
    cd "$REPO_DIR"
    
    # 3. Fetch and pull latest code for the specific branch
    echo "Updating code to latest 'structure_tools_refactoring' branch..."
    git fetch origin
    git checkout structure_tools_refactoring
    git pull origin structure_tools_refactoring

    # 4. Sync the uv environment directly onto the host's disk
    echo "Syncing uv environment..."
    uv sync
    
    echo "--------------------------------------------------------"
    echo "Setup Complete!"
    echo "Repo ready at: $REPO_DIR"
    echo "Environment synced at: $VENV_DIR"
    echo "--------------------------------------------------------"
    
    # 5. Handle the user's command
    if [ "$1" = "shell" ]; then
        # If the user passed 'shell', drop them into an interactive bash prompt
        echo "Dropping you into an interactive shell..."
        exec /bin/bash
    elif [ $# -gt 0 ]; then
        # If they passed a specific command (like a python script), run it via uv
        exec uv run "$@"
    else
        # If they ran it with no arguments, just print instructions
        echo "Container is ready."
        echo "Run with 'shell' to enter the codebase, or pass a command to execute it."
        echo "Example: apptainer run --bind /host/path:/persistent_repo contopo.sif shell"
    fi

%labels
    Author YourName
    Version 1.0
    Description ConTopo Pipeline with persistent uv environment

%help
    This container runs the ConTopo pipeline. 
    
    It is designed to automatically deploy the codebase and a 'uv' virtual 
    environment directly onto the host machine's disk for persistence.
    
    CRITICAL: You must bind-mount a local host directory to `/persistent_repo`.
    
    Example usage to get an interactive shell inside the setup repo:
    apptainer run --bind /path/on/host:/persistent_repo contopo.sif shell
    
    Example usage to run a specific script directly:
    apptainer run --bind /path/on/host:/persistent_repo contopo.sif python src/main.py