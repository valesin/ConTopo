# Copy this file to .env.secrets and fill real values.
# Source it manually before running sky, docker, or local training commands:
#   source .env.secrets

# ── Secrets (credentials — never commit real values) ────────────────────────
export AWS_ACCESS_KEY_ID="your_aws_access_key_id"
export AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
export MLFLOW_TRACKING_PASSWORD="your_mlflow_password_or_token"
export SKYPILOT_DOCKER_PASSWORD="your_github_pat"  # read:packages scope

# ── Non-sensitive config (safe to share, override as needed) ─────────────────
export MLFLOW_S3_ENDPOINT_URL="https://your-r2-or-s3-endpoint"
export MLFLOW_TRACKING_USERNAME="your_mlflow_username"
export SKYPILOT_DOCKER_USERNAME="your_github_username"
export SKYPILOT_DOCKER_SERVER="ghcr.io"

# ── MLflow / artifact storage ─────────────────────────────────────────────────
# These are passed as Hydra CLI overrides — set them here, then pass via:
#   mlflow.tracking_uri="$MLFLOW_TRACKING_URI" mlflow.artifact_location="$MLFLOW_ARTIFACT_LOCATION"
# Defaults (when not passed): local SQLite + outputs/mlruns/
export MLFLOW_TRACKING_URI="https://dagshub.com/valesin/ConTopoTEST.mlflow"
export MLFLOW_ARTIFACT_LOCATION="s3://contopotesting/mlruns"
export MLFLOW_EXPERIMENT_NAME="contopo2"

# ── Runtime tuning ────────────────────────────────────────────────────────────
# Passed as Hydra CLI overrides — uncomment and set to override defaults.
# GPU cloud defaults are defined in sky_task.yaml envs.
# export CONTOPO_DEVICE="cuda"                  # cuda | cpu | auto
# export CONTOPO_DATA_ROOT="./dataset"          # e.g. a mounted volume path
# export CONTOPO_NUM_WORKERS="4"                # dataloader workers (scale with CPU count)
# export CONTOPO_PIN_MEMORY="true"              # set false if running on CPU only
# export CONTOPO_PERSISTENT_WORKERS="true"      # keep workers alive between epochs
# export CONTOPO_INFERENCE_BATCH_SIZE="512"     # larger = faster inference, needs more VRAM
# export CONTOPO_INFERENCE_NUM_WORKERS="4"
